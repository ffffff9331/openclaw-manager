import { useState, useEffect } from "react";
import { invoke } from "@tauri-apps/api/core";
import {
  MessageSquare,
  Activity,
  Cpu,
  Wrench,
  Settings,
  Play,
  Square,
  RotateCcw,
  RefreshCw,
  Moon,
  Sun,
  CheckCircle,
  Terminal
} from "lucide-react";
import "./App.css";

// 类型定义
interface GatewayStatus {
  running: boolean;
  port: number;
  uptime?: string;
}

interface Channel {
  id: string;
  name: string;
  icon: string;
  status: "configured" | "not_configured";
  enabled: boolean;
  platform: string;
}

function App() {
  // 状态管理
  const [activeTab, setActiveTab] = useState("chat");
  const [darkMode, setDarkMode] = useState(() => {
    if (typeof window !== "undefined") {
      return window.matchMedia("(prefers-color-scheme: dark)").matches;
    }
    return true;
  });
  
  // Gateway状态
  const [gatewayStatus, setGatewayStatus] = useState<GatewayStatus>({
    running: false,
    port: 18789
  });
  
  // 实时日志
  const [liveLogs, setLiveLogs] = useState<string>("");

  // 快捷指令执行结果
  const [cmdResult, setCmdResult] = useState<{cmd: string, output: string, success: boolean} | null>(null);
  
  // 自定义快捷指令
  const [customCommands, setCustomCommands] = useState<{cmd: string, label: string, desc: string}[]>(() => {
    const saved = localStorage.getItem('customCommands');
    return saved ? JSON.parse(saved) : [];
  });
  const [showAddModal, setShowAddModal] = useState(false);
  const [newCmd, setNewCmd] = useState({ cmd: "", label: "", desc: "" });

  // 模型配置
  const [modelConfigs, setModelConfigs] = useState<any[]>([]);
  const [currentModel, setCurrentModel] = useState("");
  const [currentModelProvider, setCurrentModelProvider] = useState("");
  const [showAddModelModal, setShowAddModelModal] = useState(false);
  const [newModelConfig, setNewModelConfig] = useState({ name: "", id: "", baseUrl: "", apiKey: "" });

  // 系统诊断信息
  const [systemInfo, setSystemInfo] = useState<any>(null);
  const [doctorResult, setDoctorResult] = useState<string>("");

  // 设置
  const [settings, setSettings] = useState({
    whitelistEnabled: false,
    fileAccessEnabled: true
  });
  const [showUninstallConfirm, setShowUninstallConfirm] = useState(false);
  
  // 模型编辑
  const [editingModel, setEditingModel] = useState<any>(null);
  const [editModelForm, setEditModelForm] = useState({ name: "", id: "", baseUrl: "", apiKey: "" });

  // 侧边栏菜单 - 动态图标
  const getMenuItems = () => [
    { id: "chat", label: "对话工具", icon: MessageSquare },
    { id: "gateway", label: "Gateway", icon: gatewayStatus.running ? Activity : Play },
    { id: "tasks", label: "快捷指令", icon: Terminal },
    { id: "models", label: "模型", icon: Cpu },
    { id: "doctor", label: "测试诊断", icon: Wrench },
    { id: "settings", label: "设置", icon: Settings }
  ];
  
  // 刷新日志
  const fetchLogs = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", { command: "openclaw logs --limit 50" });
      if (result.success) {
        setLiveLogs(result.output);
      }
    } catch (e) {
      console.error("Failed to fetch logs:", e);
    }
  };
  
  // Gateway URL
  const [gatewayUrl, setGatewayUrl] = useState<string>("");
  
  // 打开 Gateway 聊天页面
  const openGatewayChat = async () => {
    try {
      // 获取 Gateway 状态
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", { 
        command: "openclaw gateway status" 
      });
      
      let url = "http://127.0.0.1:18789/";
      
      if (result.success) {
        // 解析 URL
        const match = result.output.match(/Dashboard:\s*(https?:\/\/[^\s]+)/);
        if (match) {
          url = match[1];
        }
      }
      
      setGatewayUrl(url);
      
      // 用 shell 打开浏览器
      await invoke("run_command", { command: `open "${url}"` });
    } catch (e) {
      console.error("Failed to open gateway:", e);
    }
  };
  
  // Channels状态 - 从配置读取
  const [channels, setChannels] = useState<Channel[]>([
    { id: "telegram", name: "Telegram", icon: "✈️", status: "not_configured", enabled: false, platform: "telegram" },
    { id: "discord", name: "Discord", icon: "🎮", status: "not_configured", enabled: false, platform: "discord" },
    { id: "feishu", name: "飞书", icon: "📨", status: "not_configured", enabled: false, platform: "feishu" },
    { id: "slack", name: "Slack", icon: "💬", status: "not_configured", enabled: false, platform: "slack" },
    { id: "whatsapp", name: "WhatsApp", icon: "📱", status: "not_configured", enabled: false, platform: "whatsapp" },
    { id: "signal", name: "Signal", icon: "🔒", status: "not_configured", enabled: false, platform: "signal" }
  ]);

  // 当前选中的频道配置
  const [selectedChannel, setSelectedChannel] = useState<Channel | null>(null);
  
  // Telegram 配置表单
  const [telegramConfig, setTelegramConfig] = useState({
    botToken: "",
    userId: "",
    dmPolicy: "pairing",
    groupPolicy: "open"
  });

  // 飞书配置表单
  const [feishuConfig, setFeishuConfig] = useState({
    appId: "",
    appSecret: "",
    verificationToken: ""
  });

  // Discord 配置表单
  const [discordConfig, setDiscordConfig] = useState({
    botToken: "",
    applicationId: ""
  });

  // 加载频道状态
  const loadChannelsStatus = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
        command: "openclaw channels status"
      });
      
      if (result.success) {
        const output = result.output;
        const newChannels = channels.map(ch => {
          let status: "configured" | "not_configured" = "not_configured";
          let enabled = false;
          // 解析状态：enabled, configured, running
          if (output.toLowerCase().includes(ch.id)) {
            const channelLine = output.split('\n').find(line => line.toLowerCase().includes(ch.id)) || "";
            if (channelLine.includes("configured") && channelLine.includes("running")) {
              status = "configured";
              enabled = true;
            } else if (channelLine.includes("configured")) {
              status = "configured";
            }
            if (channelLine.includes("enabled")) {
              enabled = true;
            }
          }
          return { ...ch, status, enabled };
        });
        setChannels(newChannels);
      }
    } catch (e) {
      console.error("Failed to load channels:", e);
    }
  };

  // 打开频道配置页面
  const openChannelChat = async (channel: Channel) => {
    setSelectedChannel(channel);
    // 加载已有配置
    if (channel.id === "telegram") {
      try {
        console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
          command: "openclaw config get channels.telegram"
        });
        if (result.success) {
          const config = JSON.parse(result.output);
          setTelegramConfig({
            botToken: config.botToken ? "✅ 已配置" : "",
            userId: config.userId || "",
            dmPolicy: config.dmPolicy || "pairing",
            groupPolicy: config.groupPolicy || "open"
          });
        }
      } catch (e) {
        console.error("Failed to load telegram config:", e);
      }
    }
    // 加载飞书配置
    if (channel.id === "feishu") {
      try {
        console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
          command: "openclaw config get channels.feishu"
        });
        if (result.success) {
          const config = JSON.parse(result.output);
          setFeishuConfig({
            appId: config.appId || "",
            appSecret: config.appSecret ? "✅ 已配置" : "",
            verificationToken: config.verificationToken || ""
          });
        }
      } catch (e) {
        console.error("Failed to load feishu config:", e);
      }
    }
    // 加载 Discord 配置
    if (channel.id === "discord") {
      try {
        console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
          command: "openclaw config get channels.discord"
        });
        if (result.success) {
          const config = JSON.parse(result.output);
          setDiscordConfig({
            botToken: config.botToken ? "✅ 已配置" : "",
            applicationId: config.applicationId || ""
          });
        }
      } catch (e) {
        console.error("Failed to load discord config:", e);
      }
    }
    // 加载 Slack 配置
    if (channel.id === "slack") { loadSlackConfig(); }
    // 加载 WhatsApp 配置  
    if (channel.id === "whatsapp") { loadWhatsappConfig(); }
    // 加载 Signal 配置
    if (channel.id === "signal") { loadSignalConfig(); }
  };

  // 保存 Telegram 配置
  const saveTelegramConfig = async () => {
    setSystemLoading("saving-telegram");
    try {
      // 保存 botToken
      if (telegramConfig.botToken && !telegramConfig.botToken.includes("已配置")) {
        await invoke("run_command", {
          command: `openclaw config set channels.telegram.botToken "${telegramConfig.botToken}"`
        });
      }
      // 保存 dmPolicy
      await invoke("run_command", {
        command: `openclaw config set channels.telegram.dmPolicy ${telegramConfig.dmPolicy}`
      });
      // 保存 groupPolicy
      await invoke("run_command", {
        command: `openclaw config set channels.telegram.groupPolicy ${telegramConfig.groupPolicy}`
      });
      // 保存 userId（如果有）
      if (telegramConfig.userId) {
        await invoke("run_command", {
          command: `openclaw config set channels.telegram.userId "${telegramConfig.userId}"`
        });
      }
      alert("Telegram 配置已保存！");
      setSelectedChannel(null);
      // 刷新频道状态
      await loadChannelsStatus();
      // 重启 Gateway 以应用更改
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) {
      console.error("Failed to save config:", e);
      alert("保存失败: " + e);
    }
    setSystemLoading(null);
  };

  // 保存飞书配置
  const saveFeishuConfig = async () => {
    setSystemLoading("saving-feishu");
    try {
      if (feishuConfig.appId) {
        await invoke("run_command", {
          command: `openclaw config set channels.feishu.appId "${feishuConfig.appId}"`
        });
      }
      if (feishuConfig.appSecret) {
        await invoke("run_command", {
          command: `openclaw config set channels.feishu.appSecret "${feishuConfig.appSecret}"`
        });
      }
      if (feishuConfig.verificationToken) {
        await invoke("run_command", {
          command: `openclaw config set channels.feishu.verificationToken "${feishuConfig.verificationToken}"`
        });
      }
      await invoke("run_command", { command: "openclaw config set channels.feishu.enabled true" });
      alert("飞书 配置已保存！");
      setSelectedChannel(null);
      await loadChannelsStatus();
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) {
      console.error("Failed to save config:", e);
      alert("保存失败: " + e);
    }
    setSystemLoading(null);
  };

  // 保存 Discord 配置
  const saveDiscordConfig = async () => {
    setSystemLoading("saving-discord");
    try {
      if (discordConfig.botToken) {
        await invoke("run_command", {
          command: `openclaw config set channels.discord.botToken "${discordConfig.botToken}"`
        });
      }
      if (discordConfig.applicationId) {
        await invoke("run_command", {
          command: `openclaw config set channels.discord.applicationId "${discordConfig.applicationId}"`
        });
      }
      await invoke("run_command", { command: "openclaw config set channels.discord.enabled true" });
      alert("Discord 配置已保存！");
      setSelectedChannel(null);
      await loadChannelsStatus();
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) {
      console.error("Failed to save config:", e);
      alert("保存失败: " + e);
    }
    setSystemLoading(null);
  };

  // Slack 配置
  const [slackConfig, setSlackConfig] = useState({ botToken: "", signingSecret: "" });
  
  const loadSlackConfig = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
        command: "openclaw config get channels.slack"
      });
      if (result.success) {
        const config = JSON.parse(result.output);
        setSlackConfig({
          botToken: config.botToken ? "***已配置***" : "",
          signingSecret: config.signingSecret ? "***已配置***" : ""
        });
      }
    } catch (e) { console.error("Failed to load slack config:", e); }
  };

  const saveSlackConfig = async () => {
    setSystemLoading("saving-slack");
    try {
      if (slackConfig.botToken && !slackConfig.botToken.includes("已配置")) {
        await invoke("run_command", { command: `openclaw config set channels.slack.botToken "${slackConfig.botToken}"` });
      }
      if (slackConfig.signingSecret && !slackConfig.signingSecret.includes("已配置")) {
        await invoke("run_command", { command: `openclaw config set channels.slack.signingSecret "${slackConfig.signingSecret}"` });
      }
      await invoke("run_command", { command: "openclaw config set channels.slack.enabled true" });
      alert("Slack 配置已保存！");
      setSelectedChannel(null);
      await loadChannelsStatus();
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) { alert("保存失败: " + e); }
    setSystemLoading(null);
  };

  // WhatsApp 配置
  const [whatsappConfig, setWhatsappConfig] = useState({ phoneNumberId: "", accessToken: "" });
  
  const loadWhatsappConfig = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
        command: "openclaw config get channels.whatsapp"
      });
      if (result.success) {
        const config = JSON.parse(result.output);
        setWhatsappConfig({
          phoneNumberId: config.phoneNumberId || "",
          accessToken: config.accessToken ? "***已配置***" : ""
        });
      }
    } catch (e) { console.error("Failed to load whatsapp config:", e); }
  };

  const saveWhatsappConfig = async () => {
    setSystemLoading("saving-whatsapp");
    try {
      if (whatsappConfig.phoneNumberId) {
        await invoke("run_command", { command: `openclaw config set channels.whatsapp.phoneNumberId "${whatsappConfig.phoneNumberId}"` });
      }
      if (whatsappConfig.accessToken && !whatsappConfig.accessToken.includes("已配置")) {
        await invoke("run_command", { command: `openclaw config set channels.whatsapp.accessToken "${whatsappConfig.accessToken}"` });
      }
      await invoke("run_command", { command: "openclaw config set channels.whatsapp.enabled true" });
      alert("WhatsApp 配置已保存！");
      setSelectedChannel(null);
      await loadChannelsStatus();
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) { alert("保存失败: " + e); }
    setSystemLoading(null);
  };

  // Signal 配置
  const [signalConfig, setSignalConfig] = useState({ phoneNumber: "", password: "" });
  
  const loadSignalConfig = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", {
        command: "openclaw config get channels.signal"
      });
      if (result.success) {
        const config = JSON.parse(result.output);
        setSignalConfig({
          phoneNumber: config.phoneNumber || "",
          password: config.password ? "***已配置***" : ""
        });
      }
    } catch (e) { console.error("Failed to load signal config:", e); }
  };

  const saveSignalConfig = async () => {
    setSystemLoading("saving-signal");
    try {
      if (signalConfig.phoneNumber) {
        await invoke("run_command", { command: `openclaw config set channels.signal.phoneNumber "${signalConfig.phoneNumber}"` });
      }
      if (signalConfig.password && !signalConfig.password.includes("已配置")) {
        await invoke("run_command", { command: `openclaw config set channels.signal.password "${signalConfig.password}"` });
      }
      await invoke("run_command", { command: "openclaw config set channels.signal.enabled true" });
      alert("Signal 配置已保存！");
      setSelectedChannel(null);
      await loadChannelsStatus();
      await invoke("run_command", { command: "openclaw gateway restart" });
    } catch (e) { alert("保存失败: " + e); }
    setSystemLoading(null);
  };

  // 开启/关闭频道
  const toggleChannelEnabled = async (channel: Channel) => {
    const newEnabled = !channel.enabled;
    setSystemLoading(`toggle-${channel.id}`);
    try {
      await invoke("run_command", {
        command: `openclaw config set channels.${channel.id}.enabled ${newEnabled}`
      });
      // 重启 Gateway
      await invoke("run_command", { command: "openclaw gateway restart" });
      // 刷新状态
      await loadChannelsStatus();
    } catch (e) {
      console.error("Failed to toggle channel:", e);
      alert("操作失败: " + e);
    }
    setSystemLoading(null);
  };

  // 加载频道状态
  useEffect(() => {
    loadChannelsStatus();
  }, []);
  
  const [systemLoading, setSystemLoading] = useState<string | null>(null);

  // 监听系统主题变化
  useEffect(() => {
    const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
    const handleChange = (e: MediaQueryListEvent) => setDarkMode(e.matches);
    mediaQuery.addEventListener("change", handleChange);
    return () => mediaQuery.removeEventListener("change", handleChange);
  }, []);

  // 应用主题
  useEffect(() => {
    document.documentElement.classList.toggle("dark", darkMode);
  }, [darkMode]);

  // 初始加载Gateway状态
  useEffect(() => {
    checkGatewayStatus();
    fetchLogs();
    loadModelConfigs();
    loadSystemInfo();
  }, []);

  // 切换到模型tab时刷新
  useEffect(() => {
    if (activeTab === "models") {
      loadModelConfigs();
    }
  }, [activeTab]);
  
  // 自动刷新日志（每3秒）
  useEffect(() => {
    if (activeTab === "gateway" && gatewayStatus.running) {
      const interval = setInterval(fetchLogs, 3000);
      return () => clearInterval(interval);
    }
  }, [activeTab, gatewayStatus.running]);

  // 检查Gateway状态
  const checkGatewayStatus = async () => {
    try {
      // 从 openclaw 命令获取状态
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", { command: "openclaw gateway status --json" });
      const status = JSON.parse(result.output);
      const isRunning = status.service?.runtime?.status === "running";
      
      // 获取本地检测的运行时长
      const localStatus = await invoke<{ running: boolean; port?: number; uptime?: string }>("get_gateway_status");
      
      setGatewayStatus({
        running: isRunning,
        port: status.port?.port || status.gateway?.port || 18789,
        uptime: localStatus.uptime || undefined
      });
    } catch (e) {
      console.error("Gateway status error:", e);
      setGatewayStatus({ running: false, port: 18789 });
    }
  };

  // 控制Gateway
  const controlGateway = async (action: "start" | "stop" | "restart") => {
    setSystemLoading(`gateway-${action}`);
    try {
      await invoke<string>("control_gateway", { action });
      await new Promise(r => setTimeout(r, 2000));
      await checkGatewayStatus();
    } catch (e) {
      console.error("Gateway control error:", e);
    }
    setSystemLoading(null);
  };

  // 运行诊断

  // 加载模型配置
  const loadModelConfigs = async () => {
    try {
      console.log("Calling invoke with command:", item.cmd);
                        const result = await invoke<{ success: boolean; output: string }>("run_command", { command: "openclaw config get models" });
      if (result.success && result.output) {
        const config = JSON.parse(result.output);
        // 解析 providers
        const configs: any[] = [];
        if (config.providers) {
          for (const [providerName, providerConfig] of Object.entries(config.providers as any)) {
            const pc = providerConfig as any;
            if (pc.models) {
              for (const model of pc.models) {
                configs.push({
                  provider: providerName,
                  name: model.name || model.id,
                  id: model.id,
                  baseUrl: pc.baseUrl || "",
                  apiKey: pc.apiKey ? "***已配置***" : "",
                  apiKeyRaw: pc.apiKey || "",
                  contextWindow: model.contextWindow,
                  maxTokens: model.maxTokens
                });
              }
            }
          }
        }
        setModelConfigs(configs);
        
        // 获取当前使用的模型，构建完整 key
        const defaultResult = await invoke<{ success: boolean; output: string }>("run_command", { command: "openclaw config get agents.defaults.models" });
        if (defaultResult.success) {
          const modelsConfig = JSON.parse(defaultResult.output);
          // 取第一个模型 key（当前激活的）
          const activeModelKey = Object.keys(modelsConfig)[0];
          
          if (activeModelKey) {
            const [provider, ...idParts] = activeModelKey.split('/');
            const modelId = idParts.join('/');
            setCurrentModelProvider(provider);
            setCurrentModel(modelId);
          }
        }
      }
    } catch (e) {
      console.error("Failed to load model configs:", e);
    }
  };

  // 添加模型
  const addModel = async () => {
    if (!newModelConfig.name || !newModelConfig.id || !newModelConfig.baseUrl) return;
    try {
      const providerName = `custom-${Date.now()}`;
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.baseUrl "${newModelConfig.baseUrl}"` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.apiKey "${newModelConfig.apiKey}"` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.api "openai-completions"` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.models.[0].id "${newModelConfig.id}"` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.models.[0].name "${newModelConfig.name}"` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.models.[0].contextWindow 128000` 
      });
      await invoke("run_command", { 
        command: `openclaw config set models.providers.${providerName}.models.[0].maxTokens 8192` 
      });
      alert("模型添加成功！请重启 Gateway");
      setShowAddModelModal(false);
      setNewModelConfig({ name: "", id: "", baseUrl: "", apiKey: "" });
      await loadModelConfigs();
    } catch (e) {
      alert("添加失败: " + e);
    }
  };

  // 编辑模型
  const openEditModel = (model: any) => {
    setEditingModel(model);
    setEditModelForm({
      name: model.name,
      id: model.id,
      baseUrl: model.baseUrl,
      apiKey: model.apiKeyRaw || ""
    });
  };

  // 保存模型编辑
  const saveModelEdit = async () => {
    if (!editingModel) return;
    try {
      const provider = editingModel.provider;
      // 更新模型信息
      await invoke("run_command", { 
